GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
DEBUG=False
SECRET_KEY=change-this-in-production
CACHE_TTL=300

# TikTok Research API credentials (optional)
